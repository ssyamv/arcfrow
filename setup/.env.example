# ========================================
# ArcFlow 统一部署环境变量
# 复制为 .env 后按实际情况填写
# ========================================

# === Gateway ===
GATEWAY_PORT=3100
SSH_KEY_DIR=~/.ssh

# === Dify ===
DIFY_WEB_PORT=3001
DIFY_DB_USER=dify
DIFY_DB_PASSWORD=changeme-dify-db
DIFY_DB_NAME=dify
DIFY_SECRET_KEY=changeme-dify-secret
DIFY_API_KEY=
# 各工作流独立 API Key（可选）
# DIFY_TECH_DOC_API_KEY=
# DIFY_OPENAPI_API_KEY=
# DIFY_BUG_ANALYSIS_API_KEY=

# === Plane ===
PLANE_PORT=8082
PLANE_DB_USER=plane
PLANE_DB_PASSWORD=changeme-plane-db
PLANE_DB_NAME=plane
PLANE_SECRET_KEY=changeme-plane-secret
PLANE_API_TOKEN=
PLANE_WORKSPACE_SLUG=arcflow

# === Weaviate ===
WEAVIATE_PORT=8080

# === Git 仓库（SSH 地址）===
DOCS_GIT_REPO=git@github.com:ssyamv/arcflow-docs.git
BACKEND_GIT_REPO=git@github.com:ssyamv/arcflow-backend.git
VUE3_GIT_REPO=git@github.com:ssyamv/arcflow-vue3.git
FLUTTER_GIT_REPO=git@github.com:ssyamv/arcflow-flutter.git
ANDROID_GIT_REPO=git@github.com:ssyamv/arcflow-android.git

# === Webhook 签名密钥 ===
PLANE_WEBHOOK_SECRET=
GIT_WEBHOOK_SECRET=
CICD_WEBHOOK_SECRET=

# === 飞书 ===
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# === Wiki.js ===
WIKIJS_BASE_URL=
WIKIJS_API_KEY=

# === Claude Code ===
CLAUDE_CODE_TIMEOUT=600000
